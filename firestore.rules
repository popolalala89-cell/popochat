rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============ USERS ============
    match /users/{uid} {
      allow read: if request.auth != null; // semua user terdaftar bisa lihat user lain
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ============ GROUPS ============
    match /groups/{groupId} {
      // Baca: hanya member grup yang bisa
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.members;
      // Buat: admin & broadcaster bisa
      allow create: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'broadcaster'];
      // Update: admin & broadcaster
      allow update: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'broadcaster'];
      // Delete: hanya admin
      allow delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ============ MESSAGES ============
    match /messages/{messageId} {
      // Baca: harus login
      allow read: if request.auth != null;
      // Tulis: harus login, dan harus member di grup tujuan
      allow write: if request.auth != null &&
        request.auth.uid in 
          get(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.members;
    }

    // ============ STICKERS (future) ============
    match /stickers/{stickerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'broadcaster'];
    }

    // ============ GLOBAL SETTINGS ============
    match /_settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ============ FCM TRACKING (server only via Admin SDK) ============
    match /_fcm_sent/{docId} {
      allow read, write: if false; // only accessible via Firebase Admin SDK
    }
  }
}
